# ==============================================
# Ember тАФ environment variables
# Copy this file to `.env.local` and fill in values.
# Never commit `.env.local` тАФ it's in `.gitignore`.
# ==============================================

# ---- Supabase -----------------------------------
# Dashboard тЖТ Project Settings тЖТ API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key тАФ SERVER ONLY. Bypasses RLS. Never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Claude (Anthropic) -------------------------
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---- Stripe -------------------------------------
# Dashboard тЖТ Developers тЖТ API keys
STRIPE_SECRET_KEY=sk_live_or_test_...
# Dashboard тЖТ Products тЖТ Ember Pro тЖТ copy the price ID
STRIPE_PRICE_EMBER_PRO=price_...
# Dashboard тЖТ Developers тЖТ Webhooks тЖТ your endpoint тЖТ Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- App URL ------------------------------------
# Used for building Stripe success/cancel URLs and email confirmation links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Sentry (optional, for error tracking) -----
# https://sentry.io/settings/{org}/projects/{project}/keys/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Build-time only, for source map upload
SENTRY_AUTH_TOKEN=
